{
  "name": "lao95z953.github.io",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "cross-env WATCHPACK_POLLING=true next dev --webpack",
    "dev:pages": "npm run build && wrangler pages dev",
    "build": "next build",
    "deploy": "npm run build && wrangler pages deploy out --project-name lao95z953 --branch main",
    "db:migrate:local": "wrangler d1 migrations apply lao95z953-guestbook --local",
    "db:migrate:remote": "wrangler d1 migrations apply lao95z953-guestbook --remote",
    "test": "npm run build && node --test tests/rendered-html.test.mjs",
    "lint": "eslint . --ignore-pattern out --ignore-pattern .next"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "cross-env": "^10.1.0",
    "eslint": "9.39.4",
    "eslint-config-next": "^16.2.10",
    "typescript": "5.9.3",
    "wrangler": "^4.110.0"
  },
  "overrides": {
    "postcss": "8.5.16"
  },
  "type": "module"
}
